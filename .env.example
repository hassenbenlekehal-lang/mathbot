# ── MathBot — Variables d'environnement ──────────────────────────────────────
# Copie ce fichier en .env et remplis les valeurs

# Obligatoire : Token de ton bot Telegram (obtenu via @BotFather)
TELEGRAM_TOKEN=ton_token_telegram_ici

# Obligatoire : Clé API Anthropic (obtenue sur console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optionnel : Limite de questions gratuites par jour (défaut : 3)
FREE_DAILY_LIMIT=3

# Optionnel : Chemin de la base de données SQLite (défaut : data/users.db)
DB_PATH=data/users.db
